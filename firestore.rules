rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read/write access to synchronize database across devices for this prototype
    match /products/{productId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /sales/{saleId} {
      allow read, write: if true;
    }

    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
  }
}
